{
  "experiment": "ls",
  "seed": 17,
  "num_epochs": 20,
  "batch_size": 128,
  "optimizer": "SGD",
  "lr": 0.1,
  "momentum": 0.9,
  "weight_decay": 0.0005,
  "lr_schedule": {
    "name": "MultiStepLR",
    "milestones": [
      10,
      15
    ],
    "gamma": 0.1
  },
  "loss": {
    "name": "CrossEntropyLoss",
    "label_smoothing": 0.1
  },
  "augmentations": [
    "RandomCrop(32,padding=4)",
    "RandomHorizontalFlip()"
  ],
  "device": "cuda"
}